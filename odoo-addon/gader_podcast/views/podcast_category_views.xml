<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_podcast_category_tree" model="ir.ui.view">
        <field name="name">gader_podcast.category.tree</field>
        <field name="model">gader_podcast.category</field>
        <field name="arch" type="xml">
            <list string="Podcast Categories">
                <field name="name"/>
                <field name="color" widget="color"/>
            </list>
        </field>
    </record>

    <record id="view_podcast_category_form" model="ir.ui.view">
        <field name="name">gader_podcast.category.form</field>
        <field name="model">gader_podcast.category</field>
        <field name="arch" type="xml">
            <form string="Podcast Category">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="color" widget="color"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_podcast_category" model="ir.actions.act_window">
        <field name="name">Podcast Categories</field>
        <field name="res_model">gader_podcast.category</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
