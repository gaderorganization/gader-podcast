<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_podcast_episode_tree" model="ir.ui.view">
        <field name="name">gader_podcast.episode.tree</field>
        <field name="model">gader_podcast.episode</field>
        <field name="arch" type="xml">
            <list string="Podcast Episodes">
                <field name="name"/>
                <field name="category_id"/>
                <field name="publish_date"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="view_podcast_episode_form" model="ir.ui.view">
        <field name="name">gader_podcast.episode.form</field>
        <field name="model">gader_podcast.episode</field>
        <field name="arch" type="xml">
            <form string="Podcast Episode">
                <header>
                    <field name="status" widget="statusbar" options="{'clickable': '1'}"/>
                </header>
                <sheet>
                    <field name="thumbnail" widget="image" class="oe_avatar"/>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Episode Title"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="youtube_url"/>
                            <field name="category_id"/>
                        </group>
                        <group>
                            <field name="publish_date"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Summary" name="summary">
                            <field name="summary"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_podcast_episode" model="ir.actions.act_window">
        <field name="name">Podcast Episodes</field>
        <field name="res_model">gader_podcast.episode</field>
        <field name="view_mode">tree,form</field>
    </record>
</odoo>
